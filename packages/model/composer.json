{
    "name": "shared/model",
    "description": "Shared model traits and base models for all services",
    "type": "library",
    "license": "Apache-2.0",
    "require": {
        "php": ">=8.1",
        "carbonphp/carbon-doctrine-types": "*",
        "nesbot/carbon": "^2.0|^3.0",
        "hyperf/http-server": "~3.1.0",
        "firebase/php-jwt": "^7.0",
        "hyperf/redis": "~3.1.0",
        "psr/log": "^1.0|^2.0|^3.0",
        "psr/http-server-middleware": "*",
        "psr/container": "*",
        "ramsey/uuid": "^4.9"
    },
    "autoload": {
        "psr-4": {
            "Shared\\Model\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
